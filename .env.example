# Helios 配置模板
# 复制为 .env 并填入实际值

# ── LLM (必填) ──
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://router.shengsuanyun.com/api/v1
HELIOS_LLM_MODEL=deepseek/deepseek-v4-flash
HELIOS_LLM_BACKEND=openai

# ── QQ Bot (必填, G4) ──
# 去 https://q.bot.qq.com 创建机器人获取
HELIOS_QQ_APP_ID=your_app_id
HELIOS_QQ_CLIENT_SECRET=your_client_secret
HELIOS_QQ_API_BASE=https://api.sgroup.qq.com
HELIOS_QQ_SANDBOX=1
# 主人的 openid (收到第一条消息后手动填入, 或通过环境变量设置)
HELIOS_QQ_TARGET_ID=

# ── 阿里云语音 (可选, G5/G6) ──
ALIBABA_CLOUD_ACCESS_KEY_ID=
ALIBABA_CLOUD_ACCESS_KEY_SECRET=

# ── Embedding (可选, R82 标准生产装配) ──
# 标准生产装配 assemble_production_runtime() 默认启用 SQLite 持久化 + R42 检查点 +
# experience-embedding 网关。设置下面的 API key 即启用真实 OpenAI 兼容 embedding；
# 留空则自动回退到网络无关的 DeterministicHashEmbeddingProvider（占位级，离线可用，真实质量留 P5）。
HELIOS_EMBEDDING_API_KEY=
HELIOS_EMBEDDING_BASE_URL=https://api.openai.com/v1
HELIOS_EMBEDDING_MODEL=text-embedding-3-small

# ── 主循环 (可选) ──
HELIOS_TICK_INTERVAL=0.5
HELIOS_LOG_LEVEL=INFO
HELIOS_COMFORT_DEVIATION=0.2
