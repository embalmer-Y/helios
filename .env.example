# Helios 配置模板
# 复制为 .env 并填入实际值

# ── LLM (必填) ──
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://router.shengsuanyun.com/api/v1
HELIOS_LLM_MODEL=deepseek/deepseek-v4-flash
HELIOS_LLM_BACKEND=openai

# ── QQ Bot (必填, G4) ──
# 去 https://q.bot.qq.com 创建机器人获取
HELIOS_QQ_APP_ID=your_app_id
HELIOS_QQ_CLIENT_SECRET=your_client_secret
HELIOS_QQ_API_BASE=https://api.sgroup.qq.com
HELIOS_QQ_SANDBOX=1
# 主人的 openid (收到第一条消息后手动填入, 或通过环境变量设置)
HELIOS_QQ_TARGET_ID=

# ── 阿里云语音 (可选, G5/G6) ──
ALIBABA_CLOUD_ACCESS_KEY_ID=
ALIBABA_CLOUD_ACCESS_KEY_SECRET=

# ── 主循环 (可选) ──
HELIOS_TICK_INTERVAL=0.5
HELIOS_LOG_LEVEL=INFO
HELIOS_COMFORT_DEVIATION=0.2
