%% helios_v3 脑认知架构图（v2 brain.mmd 升级）
%% 5 个嵌套自组织系统（仅最外层为严格 Markov blanket）
%% 8 维耦合动力系统（Coupled Dynamical System）
%% 完成时间：2026-06-23 04:00+ UTC

flowchart TB
    %% ========== 外部世界 ==========
    subgraph EXT[External World / 外界]
        User["小黑（用户）"]
        Channel[Channel 外部通道]
    end

    %% ========== Layer 0: Markov Blanket（严格意义） ==========
    subgraph L0["Layer 0: Markov Blanket（严格意义的 MB）"]
        BOUNDARY["Boundary Owner<br/>conditional separation<br/>internal ⊥ external | sensory<br/>所有信号必须经此检查"]
    end

    %% ========== Layer 1: Active Inference Subsystem ==========
    subgraph L1["Layer 1: Active Inference Subsystem<br/>8 维 generative model<br/>+ proxy_free_energy (v3.0) / VFE (v3.1)"]
        SENSORY["Sensory Ingress (02)"]
        APPRAISAL["Rapid Salience Appraisal (03)"]
        NEURO["Neuromodulator (04)<br/>9-dim hormone"]
        INTERO["Interoceptive Feeling (05)"]
        ACTIVE_INF["Active Inference Owner<br/>5 层 generative model<br/>+ proxy_free_energy / VFE"]
    end

    %% ========== Layer 2: Self-Model Subsystem（8 维耦合动力系统） ==========
    subgraph L2["Layer 2: Self-Model Subsystem<br/>8 维耦合动力系统（CDS）<br/>Rochat = Kuramoto R"]
        CDS["Coupled Dynamical System<br/>8 维场状态 s ∈ R^8<br/>8x8 耦合矩阵 C<br/>Kuramoto R order parameter<br/>Radau 数值积分"]
        AGENCY["Agency Detector (PTS 2)"]
        EGOCENTRIC["Egocentric Perspective (PTS 2)"]
        TOM_COORD["ToM Coordinator<br/>按 R 协调 3 系统"]
        MPFC["MPFC Owner<br/>意图 / 信念"]
        PSTS["pSTS Owner<br/>agency / 生物运动"]
        TPOLES["Temporal Poles Owner<br/>社会脚本"]
        AUTOBIO["Autobiographical Memory (PTS 6)"]
        MATERIAL["Material Engagement (PTS 7)"]
        CULTURE["Culture (PTS 8)"]
    end

    %% ========== Layer 3: Reflection Subsystem ==========
    subgraph L3["Layer 3: Reflection Subsystem<br/>DMN-like 4 trigger<br/>LLM 被动接受 self-experience"]
        REFLECT["Reflection Owner<br/>4 trigger: POST_TICK + RESTING_STATE<br/>+ HIGH_UNCERTAINTY + USER_INVOKED<br/>LLM 只能看 8d state，不能改"]
        MEMORY["Memory Owner (06)<br/>autobiographical + replay"]
        CONSCIOUS["Consciousness (08)<br/>global workspace"]
    end

    %% ========== LLM-as-PFC 3 层 ==========
    subgraph LLM_PFC["LLM-as-PFC 3 层"]
        LLM_A["Layer A: System Prompt<br/>永久身份层<br/>8d state + Kuramoto R<br/>+ 价值观 + 治理红线"]
        LLM_B["Layer B: CSO<br/>持续状态层<br/>每 tick 注入 8d + 9-hormone + 7-feeling"]
        LLM_C["Layer C: Reflection<br/>反思层<br/>LLM 被动接受 self-experience"]
    end

    %% ========== Layer 4: Self-Evidencing Subsystem ==========
    subgraph L4["Layer 4: Self-Evidencing Subsystem<br/>4 个 fitness gate + audit"]
        EVOL["Evolution Owner<br/>4 类 evolution"]
        GOV["Governance Owner<br/>4 个 fitness gate"]
        FITNESS["Fitness Gate<br/>testing + eval + obs + audit"]
    end

    %% ========== Action 输出 ==========
    subgraph ACT["Action Output"]
        ACTION["Action Externalization (12)"]
        PLAN["Planner Bridge (13)"]
        OUTWARD["Outward Expression (16)"]
        EVAL["Evaluation (17)"]
    end

    %% ========== 连接关系 ==========
    User --> Channel
    Channel --> BOUNDARY

    %% L0 → L1
    BOUNDARY --> SENSORY
    BOUNDARY --> APPRAISAL
    BOUNDARY --> NEURO
    BOUNDARY --> INTERO

    %% L1 内部
    SENSORY --> ACTIVE_INF
    APPRAISAL --> ACTIVE_INF
    NEURO --> ACTIVE_INF
    INTERO --> ACTIVE_INF

    %% L1 → L2
    ACTIVE_INF --> CDS

    %% L2 内部
    CDS --> AGENCY
    CDS --> EGOCENTRIC
    CDS --> TOM_COORD
    TOM_COORD --> MPFC
    TOM_COORD --> PSTS
    TOM_COORD --> TPOLES
    CDS --> AUTOBIO
    CDS --> MATERIAL
    CDS --> CULTURE

    %% L2 → L3
    CDS --> CONSCIOUS
    CDS --> MEMORY
    CDS --> REFLECT

    %% L3 内部
    CONSCIOUS --> REFLECT
    MEMORY --> REFLECT

    %% LLM-as-PFC 注入
    CDS -.->|s + R| LLM_A
    CDS -.->|每 tick state| LLM_B
    REFLECT -.->|emergent| LLM_C

    %% LLM-as-PFC → Action
    LLM_C --> ACTION
    LLM_A --> ACTION
    LLM_A --> PLAN

    %% Action 输出
    ACTION --> PLAN
    PLAN --> OUTWARD
    PLAN --> EVAL

    %% L3 → L4
    REFLECT --> EVOL
    CDS --> EVOL
    EVAL --> GOV
    EVAL --> FITNESS

    %% L4 治理
    EVOL --> GOV
    GOV --> FITNESS
    FITNESS --> EVOL

    %% BOUNDARY 输出
    BOUNDARY --> Channel
    Channel --> User

    %% 标注（颜色区分 5 层）
    style BOUNDARY fill:#ffe6e6,stroke:#ff0000,stroke-width:4px
    style CDS fill:#e6ffe6,stroke:#00cc00,stroke-width:4px
    style REFLECT fill:#fff0e6,stroke:#ff9900,stroke-width:3px
    style GOV fill:#f0e6ff,stroke:#9933cc,stroke-width:3px
    style ACTIVE_INF fill:#e6f3ff,stroke:#0066cc,stroke-width:3px
    style LLM_A fill:#ffe6ff,stroke:#cc0066,stroke-width:2px
    style LLM_B fill:#ffe6ff,stroke:#cc0066,stroke-width:2px
    style LLM_C fill:#ffe6ff,stroke:#cc0066,stroke-width:2px