    {"name": "hormone_plateau", "hormone": "cortisol", "plateau_start": 10, "plateau_window": 5, "tolerance": 0.05},
    {"name": "hormone_dead_code", "hormone": "serotonin", "tolerance": 0.005},
    {"name": "hormone_dead_code", "hormone": "oxytocin", "tolerance": 0.005},
